{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "lib": ["ES2022"],
    "resolveJsonModule": true
  },
  "include": [
    "main.ts",
    "preload.ts",
    "server.ts",
    "dlive.ts",
    "dlive-provider.ts",
    "shared/**/*.ts",
    "test/**/*.ts",
    "types/**/*.d.ts"
  ]
}
